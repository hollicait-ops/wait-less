{
  "name": "waitless-host",
  "version": "0.1.0",
  "description": "WaitLess host — screen capture and streaming to Fire Stick",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint .",
    "test-receiver": "npx serve test-receiver -p 3000"
  },
  "dependencies": {
    "robotjs": "^0.6.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.2",
    "eslint": "^8.57.1"
  },
  "build": {
    "appId": "com.waitless.host",
    "productName": "WaitLess",
    "win": {
      "target": "nsis"
    },
    "extraResources": []
  }
}
