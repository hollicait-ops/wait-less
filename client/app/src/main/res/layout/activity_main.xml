<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#130F32"
    android:padding="48dp">

    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="16dp"
        android:contentDescription="@string/app_name" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="32sp"
        android:textColor="#08F7FA"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="32dp" />

    <EditText
        android:id="@+id/et_host_ip"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:hint="@string/hint_host_ip"
        android:inputType="text"
        android:textColor="#FFFFFF"
        android:textColorHint="#8090B0"
        android:background="#1E2650"
        android:padding="14dp"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/btn_connect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_connect"
        android:textColor="#130F32"
        android:textStyle="bold"
        android:textSize="14sp"
        android:background="@drawable/btn_connect_bg"
        android:paddingStart="30dp"
        android:paddingEnd="30dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:focusable="true"
        android:clickable="true" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#F776F5"
        android:textSize="14sp"
        android:layout_marginTop="24dp" />

</LinearLayout>
